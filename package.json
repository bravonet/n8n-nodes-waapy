{
  "name": "n8n-nodes-waapy",
  "version": "0.3.0",
  "description": "Custom n8n nodes for the WaaPy API",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://waapy.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bravonet/n8n-nodes-waapy.git"
  },
  "bugs": {
    "url": "https://github.com/bravonet/n8n-nodes-waapy/issues"
  },
  "author": {
    "name": "Bravo Net Solution",
    "email": "support@bravonet.my"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release:it": "release-it",
    "prepare": "husky"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WaapyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Waapy/Waapy.node.js",
      "dist/nodes/WaapyTrigger/WaapyTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@n8n/node-cli": "*",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^20.0.0",
    "eslint": "9.32.0",
    "husky": "^9.1.7",
    "prettier": "3.6.2",
    "release-it": "^19.2.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
